asset StarTile: tiles8
    hex
        00 00 00 00 00 00 00 00
        00 00 00 00 00 00 00 00
        00 00 00 11 11 00 00 00
        00 00 11 11 11 11 00 00
        00 00 11 11 11 11 00 00
